.question-viewer {
  width: 100%;
}

.question {
  background-color: #fff;
  margin-bottom: 20rpx;
  padding: 20rpx;
}

.questionInfo {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.process {
  flex: 1;
  display: flex;
  align-items: center;
}

.process text {
  margin-left: 16rpx;
  font-size: 24rpx;
  color: #666;
}

.mode-class {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #666;
  margin-left: 20rpx;
}

.tags {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 16rpx;
}

.box-bound {
  padding: 6rpx 16rpx;
  background-color: #f0f0f0;
  border-radius: 8rpx;
  font-size: 22rpx;
  color: #666;
  margin-right: 12rpx;
  margin-bottom: 8rpx;
}

.questionTexts {
  font-size: 30rpx;
  line-height: 1.6;
  color: #333;
  margin-bottom: 20rpx;
}

.options {
  background-color: #fff;
  padding: 20rpx;
}

.option {
  padding: 20rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
  background-color: #fff;
}

.option.correct {
  background-color: #e8f5e9;
  border-color: #4caf50;
  color: #2e7d32;
}

.option.wrong {
  background-color: #ffebee;
  border-color: #f44336;
  color: #c62828;
}

.optionType {
  background-color: #fff;
  padding: 20rpx;
}

.optionTyped {
  padding: 16rpx 24rpx;
  margin-bottom: 12rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #333;
  background-color: #fff;
  text-align: center;
}

.optionTyped.correct {
  background-color: #e8f5e9;
  border-color: #4caf50;
  color: #2e7d32;
}

.optionTyped.wrong {
  background-color: #ffebee;
  border-color: #f44336;
  color: #c62828;
}

.icons {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background-color: #fff;
  padding: 20rpx;
}

.like {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #666;
}

.sm-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 8rpx;
}

.right-icon {
  display: flex;
  align-items: center;
}

.favorQuestion, .foreQuestion, .nextQuestion, .listQuestion {
  width: 50rpx;
  height: 50rpx;
  margin-left: 20rpx;
}

.comments {
  background-color: #fff;
  padding: 20rpx;
  margin-top: 20rpx;
}

.borders {
  padding: 16rpx 0;
}

.feeds {
  font-size: 26rpx;
  line-height: 1.8;
  color: #333;
}

.answers {
  margin-bottom: 8rpx;
}

.correct {
  color: #4caf50;
}

.wrong {
  color: #f44336;
}

.separator {
  height: 1rpx;
  background-color: #e0e0e0;
  margin: 16rpx 0;
}

.commentsimg {
  margin-top: 16rpx;
}

.knowledge-points {
  background-color: #fff;
  padding: 20rpx;
  margin-top: 20rpx;
}

.title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.points {
  margin-bottom: 16rpx;
}

.point-name {
  display: inline-block;
  padding: 8rpx 20rpx;
  background-color: #e3f2fd;
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #1569e4;
}
