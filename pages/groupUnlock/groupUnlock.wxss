page {
  background-color: #f5f5f5;
}

.page {
  min-height: 100vh;
  padding-bottom: 160rpx;
}

/* 顶部封面区域 */
.header {
  position: relative;
  height: 400rpx;
  overflow: hidden;
}

.header-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.header-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(to bottom, rgba(0,0,0,0.3) 0%, rgba(0,0,0,0.6) 100%);
  display: flex;
  align-items: flex-end;
}

.header-content {
  padding: 40rpx;
  width: 100%;
}

.title {
  font-size: 48rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 12rpx;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.3);
}

.subtitle {
  font-size: 28rpx;
  color: rgba(255,255,255,0.9);
}

/* 内容区域 */
.container {
  padding: 0 30rpx;
  margin-top: -40rpx;
  position: relative;
  z-index: 1;
}

/* 课程信息卡片 */
.product-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.08);
}

.product-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.product-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 20rpx;
}

.price-row {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}

.group-price {
  font-size: 44rpx;
  font-weight: 700;
  color: #ff4757;
}

.original-price {
  font-size: 28rpx;
  color: #999;
  text-decoration: line-through;
}

.price-tag {
  font-size: 24rpx;
  color: #ff4757;
  background: rgba(255,71,87,0.1);
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}

/* 区块样式 */
.section {
  margin-bottom: 30rpx;
}

.section-header {
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  position: relative;
  padding-left: 20rpx;
}

.section-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 28rpx;
  background: linear-gradient(180deg, #667eea 0%, #764ba2 100%);
  border-radius: 4rpx;
}

/* 拼单成员 */
.members-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
}

.member-list {
  display: flex;
  justify-content: space-around;
  align-items: center;
}

.member-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.member-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 4rpx solid #667eea;
  box-sizing: border-box;
  overflow: hidden;
}

.member-avatar.placeholder {
  background: #f0f0f0;
  border: 4rpx dashed #ccc;
  display: flex;
  align-items: center;
  justify-content: center;
}

button.member-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  padding: 0;
  margin: 0;
  line-height: inherit;
}

.placeholder-text {
  font-size: 40rpx;
  color: #999;
}

.member-name {
  font-size: 24rpx;
  color: #666;
  max-width: 120rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.member-item.empty .member-name {
  color: #999;
}

.member-count-inline {
  font-size: 24rpx;
  color: #999;
  margin-left: 12rpx;
}

.countdown-text {
  font-size: 22rpx;
  color: #ff4757;
  background: rgba(255, 71, 87, 0.1);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  margin-left: auto;
  font-weight: 500;
}

.success-badge {
  font-size: 22rpx;
  color: #52c41a;
  background: rgba(82, 196, 26, 0.1);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  margin-left: auto;
  font-weight: 500;
}

.invite-btn-wrapper {
  margin-top: 30rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.invite-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 28rpx;
  padding: 24rpx 0;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  width: 100%;
  line-height: inherit;
}

.invite-btn::after {
  border: none;
}

.share-btn {
  background: transparent;
  padding: 0;
  margin: 0;
  border: none;
  line-height: inherit;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
}

button.invite-btn.share-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  padding: 24rpx 0;
  border-radius: 40rpx;
}

.share-btn::after {
  border: none;
}

.invite-icon {
  font-size: 32rpx;
}

.invite-text {
  font-weight: 500;
}

.cancel-btn {
  text-align: center;
  font-size: 26rpx;
  color: #999;
  padding: 16rpx 0;
}

.success-action {
  margin-top: 30rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.view-delivery-btn {
  background: linear-gradient(135deg, #52c41a 0%, #389e0d 100%);
  color: #fff;
  font-size: 28rpx;
  padding: 24rpx 0;
  border-radius: 40rpx;
  text-align: center;
  font-weight: 500;
}

/* 被邀请人加入区域 */
.join-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
}

.join-tip {
  font-size: 28rpx;
  color: #666;
}

.join-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 30rpx;
  padding: 24rpx 80rpx;
  border-radius: 44rpx;
  font-weight: 600;
}

/* 规则卡片 */
.rules-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
}

.rule-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.rule-item:last-child {
  margin-bottom: 0;
}

.rule-icon {
  width: 40rpx;
  height: 40rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 24rpx;
  font-weight: 600;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.rule-text {
  font-size: 28rpx;
  color: #555;
  line-height: 1.5;
  padding-top: 4rpx;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.08);
  z-index: 100;
}

.price-info {
  display: flex;
  flex-direction: column;
}

.price-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 4rpx;
}

.price-row-bottom {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}

.bottom-bar .group-price {
  font-size: 40rpx;
}

.original-price-small {
  font-size: 22rpx;
  color: #999;
  text-decoration: line-through;
}

.btn-group {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.btn-buy {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 28rpx;
  padding: 20rpx 40rpx;
  border-radius: 40rpx;
  font-weight: 600;
}

.btn-buy.disabled {
  background: #ccc;
  color: #fff;
}

.btn-direct {
  background: #fff;
  color: #667eea;
  border: 2rpx solid #667eea;
  font-size: 26rpx;
  padding: 18rpx 30rpx;
  border-radius: 40rpx;
  font-weight: 500;
}

/* 激活码弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 200;
}

.code-modal {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: #fff;
  border-radius: 20rpx;
  width: 80%;
  max-width: 600rpx;
  z-index: 201;
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.modal-close {
  font-size: 40rpx;
  color: #999;
  padding: 0 10rpx;
}

.modal-body {
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
}

.code-display {
  font-size: 48rpx;
  font-weight: 700;
  color: #667eea;
  letter-spacing: 4rpx;
  background: #f5f5f5;
  padding: 30rpx 40rpx;
  border-radius: 12rpx;
  font-family: monospace;
}

.code-tip {
  font-size: 26rpx;
  color: #666;
  text-align: center;
}

.copy-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 28rpx;
  padding: 20rpx 60rpx;
  border-radius: 40rpx;
  font-weight: 500;
}

.qr-code {
  width: 300rpx;
  height: 300rpx;
  border-radius: 12rpx;
}

.qr-tip {
  font-size: 24rpx;
  color: #999;
}
