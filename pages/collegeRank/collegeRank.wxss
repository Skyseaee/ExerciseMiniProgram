.page {
  min-height: 100vh;
  background-color: #f7f7f7;
  padding-bottom: 40rpx;
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 30rpx;
  background-color: #fff;
  position: sticky;
  top: 0;
  z-index: 100;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.back-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #202020;
}

.header-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #202020;
}

.header-right {
  width: 60rpx;
}

.content {
  padding: 30rpx;
}

.podium-section {
  display: flex;
  align-items: flex-end;
  justify-content: center;
  margin-bottom: 20rpx;
  gap: 12rpx;
}

.podium-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  background-color: #fff;
  border-radius: 16rpx;
  padding: 20rpx 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  position: relative;
}

.second-place, .third-place {
  width: 180rpx;
}

.first-place {
  width: 200rpx;
}

.rank-badge {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 10rpx;
}

.second-place .rank-badge {
  background: linear-gradient(135deg, #a0a0a0 0%, #c0c0c0 100%);
}

.first-place .rank-badge {
  background: linear-gradient(135deg, #ffd700 0%, #ffb347 100%);
}

.third-place .rank-badge {
  background: linear-gradient(135deg, #cd7f32 0%, #daa06d 100%);
}

.college-name {
  font-size: 24rpx;
  font-weight: 600;
  color: #202020;
  margin-bottom: 6rpx;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  width: 100%;
}

.college-votes {
  font-size: 20rpx;
  color: #808080;
  margin-bottom: 12rpx;
}

.vote-btn {
  padding: 10rpx 24rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-radius: 24rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.vote-btn.primary {
  padding: 12rpx 36rpx;
  font-size: 24rpx;
}

.search-section {
  margin-bottom: 20rpx;
}

.province-scroll {
  display: flex;
  white-space: nowrap;
  height: 72rpx;
}

.province-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 14rpx 28rpx;
  background-color: #fff;
  border-radius: 32rpx;
  font-size: 24rpx;
  color: #666;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.province-tag.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
}

.province-result {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.result-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #202020;
  margin-bottom: 16rpx;
}

.province-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.province-item:last-child {
  border-bottom: none;
}

.province-rank {
  width: 44rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #808080;
}

.province-info {
  flex: 1;
}

.province-name-row {
  display: flex;
  align-items: center;
  padding: 0 24rpx 0 12rpx;
  justify-content: space-between;
}

.province-name {
  font-size: 26rpx;
  font-weight: 500;
  color: #202020;
}

.province-votes {
  font-size: 24rpx;
  color: #ff6b6b;
}

.province-vote-btn {
  padding: 10rpx 24rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-radius: 24rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.clear-provinve {
  text-align: center;
  padding: 16rpx;
  color: #808080;
  font-size: 24rpx;
  margin-top: 12rpx;
  border-top: 1rpx solid #f5f5f5;
}

.list-section {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #202020;
  margin-bottom: 16rpx;
  padding-bottom: 12rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.list-item {
  display: flex;
  align-items: center;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.list-item:last-child {
  border-bottom: none;
}

.list-rank {
  width: 44rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #808080;
}

.list-rank.top-six {
  color: #ff6b6b;
}

.list-info {
  flex: 1;
}

.list-name-row {
  display: flex;
  align-items: center;
  padding-left: 8rpx;
  padding-right: 24rpx;
  justify-content: space-between;
}

.list-name {
  font-size: 26rpx;
  font-weight: 500;
  color: #202020;
}

.list-votes {
  font-size: 24rpx;
  color: #ff6b6b;
}

.list-vote-btn {
  padding: 10rpx 24rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-radius: 24rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.load-more {
  text-align: center;
  padding: 24rpx;
  color: #808080;
  font-size: 24rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
}

.empty-image {
  width: 300rpx;
  height: 300rpx;
  margin-bottom: 40rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #808080;
}
